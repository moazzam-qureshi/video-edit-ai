# Copy to .env on the VPS and fill in. .env is gitignored.

# OpenRouter (Phase 2 & 3 vision / brain experiments)
OPENROUTER_API_KEY=

# Default model picks per tier (override per-experiment as needed)
VISION_MODEL_FLASH=qwen/qwen-vl-flash
VISION_MODEL_PLUS=qwen/qwen-vl-plus
BRAIN_MODEL=google/gemini-2.5-flash

# CTranslate2 / OpenMP tuning for Ryzen 5 3600 (per vps_specs.md)
OMP_NUM_THREADS=4
CT2_USE_EXPERIMENTAL_PACKED_GEMM=1

# Paths
SAMPLES_DIR=./samples
OUTPUTS_DIR=./outputs
