# Copy to .env on the VPS and fill in. .env is gitignored.

# OpenRouter (Phase 2 & 3 vision / brain experiments)
OPENROUTER_API_KEY=

# Default model picks per tier — verified against live OpenRouter catalog 2026-05-17.
# Tier 1 (bulk VM-1/VM-3/VM-7): cheapest VL with no separate image surcharge.
# Tier 2 (quality VM-2/VM-4/VM-5): mid-size VL.
# Tier 3 (Brain EDL): cheap-tier flash for structured output.
VISION_MODEL_FLASH=qwen/qwen3-vl-8b-instruct
VISION_MODEL_PLUS=qwen/qwen3-vl-32b-instruct
BRAIN_MODEL=google/gemini-2.5-flash-lite

# CTranslate2 / OpenMP tuning for Ryzen 5 3600 (per vps_specs.md)
OMP_NUM_THREADS=4
CT2_USE_EXPERIMENTAL_PACKED_GEMM=1

# Paths
SAMPLES_DIR=./samples
OUTPUTS_DIR=./outputs
